@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center py-5 animate-fade-in stagger-1">
    <div class="mb-5">
        <h1 class="display-3 fw-bold text-primary-gradient mb-3">Intelligent Attendance</h1>
        <p class="lead text-muted fs-4 px-md-5">Next-generation classroom attendance using advanced facial recognition.</p>
    </div>
    
    <div class="row justify-content-center mb-5 animate-fade-in stagger-2">
        <div class="col-md-5 col-lg-4 mb-4">
            <div class="card h-100 cursor-pointer">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <div class="d-inline-flex p-3 rounded-circle bg-primary bg-opacity-10">
                            <i class="bi bi-camera-video-fill text-primary" style="font-size: 2.5rem;"></i>
                        </div>
                    </div>
                    <h4 class="card-title fw-bold mb-3">Instant Recognition</h4>
                    <p class="card-text text-muted">Use any standard webcam to quickly identify students and mark them present in real-time without manual roll calls.</p>
                </div>
            </div>
        </div>
        <div class="col-md-5 col-lg-4 mb-4">
            <div class="card h-100">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <div class="d-inline-flex p-3 rounded-circle bg-success bg-opacity-10">
                            <i class="bi bi-graph-up-arrow text-success" style="font-size: 2.5rem;"></i>
                        </div>
                    </div>
                    <h4 class="card-title fw-bold mb-3">Smart Analytics</h4>
                    <p class="card-text text-muted">Students can view their comprehensive attendance history and visualize their presence rate over time via beautiful charts.</p>
                </div>
            </div>
        </div>
    </div>
    
    <div class="mt-2 animate-fade-in stagger-3">
        @if (User.Identity.IsAuthenticated)
        {
            if (User.IsInRole("Admin") || User.Claims.Any(c => c.Value == "Admin"))
            {
                <a class="btn btn-primary btn-lg rounded-pill px-5 py-3 shadow-lg fs-5" asp-controller="Admin" asp-action="Dashboard">
                    <i class="bi bi-camera-fill me-2"></i> Launch Scanner
                </a>
            }
            else
            {
                <a class="btn btn-primary btn-lg rounded-pill px-5 py-3 shadow-lg fs-5" asp-controller="Student" asp-action="Dashboard">
                    <i class="bi bi-bar-chart-fill me-2"></i> View My Analytics
                </a>
            }
        }
        else
        {
            <a class="btn btn-primary btn-lg rounded-pill px-5 py-3 shadow-lg fs-5" asp-controller="Account" asp-action="Login">
                Get Started <i class="bi bi-arrow-right ms-2"></i>
            </a>
        }
    </div>
</div>

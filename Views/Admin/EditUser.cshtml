@model IntelligentAttendanceSystem.Models.User

@{
    ViewData["Title"] = "Edit User";
}

<div class="row justify-content-center animate-fade-in stagger-1">
    <div class="col-md-7 col-lg-6">
        <div class="card border-0 shadow-lg" style="border-radius: 16px;">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <div class="d-flex align-items-center">
                    <a href="/Admin/ManageUsers" class="btn btn-light rounded-circle me-3" style="width: 40px; height: 40px;">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    <h4 class="mb-0 fw-bold text-dark">Edit User Profile</h4>
                </div>
            </div>
            <div class="card-body p-4">
                <form asp-action="EditUser" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-semibold text-muted small text-uppercase">Full Name</label>
                        <input asp-for="Name" class="form-control form-control-lg bg-light border-0 px-3" placeholder="Enter user name" style="border-radius: 12px;" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-semibold text-muted small text-uppercase">Email Address</label>
                        <input asp-for="Email" type="email" class="form-control form-control-lg bg-light border-0 px-3" placeholder="user@example.com" style="border-radius: 12px;" required />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="Role" class="form-label fw-semibold text-muted small text-uppercase">System Role</label>
                            <select asp-for="Role" class="form-select form-select-lg bg-light border-0 px-3" style="border-radius: 12px;">
                                <option value="Student">Student</option>
                                <option value="Admin">Admin</option>
                                <option value="Employee">Employee</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Department" class="form-label fw-semibold text-muted small text-uppercase">Department</label>
                            <select asp-for="Department" class="form-select form-select-lg bg-light border-0 px-3" style="border-radius: 12px;">
                                <option value="Computer Science">Computer Science</option>
                                <option value="BCA">BCA</option>
                                <option value="Mechanical">Mechanical</option>
                                <option value="Electrical">Electrical</option>
                                <option value="Civil">Civil</option>
                                <option value="IT">IT</option>
                                <option value="B.Tech">B.Tech</option>
                                <option value="General">General</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-5">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow-sm fw-bold py-3 animate-pulse">
                             Save Changes
                        </button>
                        <a href="/Admin/ManageUsers" class="btn btn-link text-muted fw-medium text-decoration-none">
                            Discard Changes
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IntelligentAttendanceSystem</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/IntelligentAttendanceSystem.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex w-100 min-vh-100 bg-light-gradient">
        @if (User.Identity.IsAuthenticated)
        {
            <!-- Sidebar -->
            <aside class="sidebar bg-white border-end d-flex flex-column p-4" style="width: 250px; flex-shrink: 0;">
                <a class="navbar-brand mb-5 d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <div class="bg-primary text-white rounded p-2 me-2 d-flex align-items-center justify-content-center">
                        <i class="bi bi-camera fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-dark lh-1">Smart Attendance</div>
                        <small class="text-muted fw-normal" style="font-size: 0.65rem;">AI-Powered Analytics System</small>
                    </div>
                </a>

                <ul class="nav nav-pills flex-column mb-auto sidebar-nav gap-2">
                    @if (User.IsInRole("Admin") || User.Claims.Any(c => c.Value == "Admin"))
                    {
                        <li class="nav-item">
                            <a href="/Admin/DashboardOverview" class="nav-link text-muted d-flex align-items-center">
                                <i class="bi bi-grid me-3"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/Admin/Dashboard" class="nav-link text-muted d-flex align-items-center">
                                <i class="bi bi-camera me-3"></i> Mark Attendance
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/Admin/Records" class="nav-link text-muted d-flex align-items-center">
                                <i class="bi bi-file-earmark-text me-3"></i> Records
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/Admin/Analytics" class="nav-link text-muted d-flex align-items-center">
                                <i class="bi bi-bar-chart-line me-3"></i> Analytics
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/Admin/ManageUsers" class="nav-link text-muted d-flex align-items-center">
                                <i class="bi bi-people me-3"></i> Manage Users
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/Admin/Reports" class="nav-link text-muted d-flex align-items-center">
                                <i class="bi bi-file-earmark-bar-graph me-3"></i> Reports
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/Admin/Alerts" class="nav-link text-muted d-flex align-items-center">
                                <i class="bi bi-bell me-3"></i> Alerts
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a href="/Student/Dashboard" class="nav-link text-muted d-flex align-items-center">
                                <i class="bi bi-grid me-3"></i> My Analytics
                            </a>
                        </li>
                    }
                </ul>
                
                <hr />
                <div class="dropdown">
                    <a href="#" class="d-flex align-items-center text-dark text-decoration-none dropdown-toggle" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="https://ui-avatars.com/api/?name=@User.Identity.Name&background=random" alt="" width="32" height="32" class="rounded-circle me-2">
                        <strong>@User.Identity.Name</strong>
                    </a>
                    <ul class="dropdown-menu text-small shadow" aria-labelledby="dropdownUser1">
                        <li><a class="dropdown-item" href="#">Profile</a></li>
                        <li><a class="dropdown-item" href="#">Settings</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" asp-area="" asp-controller="Account" asp-action="Logout">Sign out</a></li>
                    </ul>
                </div>
            </aside>
        }

        <!-- Main Content Wrapper -->
        <div class="flex-grow-1 d-flex flex-column w-100 overflow-hidden">
            @if (User.Identity.IsAuthenticated)
            {
                <header class="bg-white border-bottom py-3 px-4 d-flex justify-content-between align-items-center">
                    <div><!-- Left side empty for spacing --></div>
                    <div class="text-end">
                        <div class="text-muted small fw-medium">@(User.IsInRole("Admin") || User.Claims.Any(c=>c.Value=="Admin") ? "Admin Dashboard" : "Student Dashboard")</div>
                        <div class="text-muted small">@DateTime.Now.ToShortDateString()</div>
                    </div>
                </header>
            }
            else
            {
                 <header class="bg-white border-bottom py-3 px-4 d-flex justify-content-between align-items-center">
                     <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                        <div class="bg-primary text-white rounded p-1 me-2 d-flex align-items-center justify-content-center">
                            <i class="bi bi-camera"></i>
                        </div>
                        <div class="fw-bold text-dark lh-1">Smart Attendance</div>
                    </a>
                    <a class="btn btn-outline-primary rounded-pill px-4" asp-controller="Account" asp-action="Login">Login</a>
                 </header>
            }

            <main role="main" class="flex-grow-1 overflow-auto p-4 bg-light">
                <div class="container-fluid max-w-7xl">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - IntelligentAttendanceSystem - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
